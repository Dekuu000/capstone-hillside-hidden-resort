{
  "name": "hillside-monorepo",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "hillside-next",
    "hillside-contracts",
    "packages/shared"
  ],
  "scripts": {
    "dev:react": "npm --prefix hillside-app run dev",
    "dev:next": "npm --prefix hillside-next run dev",
    "dev:api": "hillside-api\\.venv\\Scripts\\python.exe -m uvicorn app.main:app --reload --port 8000 --app-dir hillside-api --env-file hillside-api/.env",
    "dev:ai": "hillside-ai\\.venv\\Scripts\\python.exe -m uvicorn app.main:app --reload --port 8100 --app-dir hillside-ai",
    "dev:stack": "powershell -ExecutionPolicy Bypass -File scripts/dev-local.ps1",
    "dev:stack:ai": "powershell -ExecutionPolicy Bypass -File scripts/dev-local.ps1 -WithAi",
    "dev:contracts": "npx --prefix hillside-contracts hardhat node",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset",
    "db:sanity": "python supabase/scripts/migration_sanity_check.py",
    "db:hygiene": "python supabase/scripts/migration_hygiene_check.py",
    "db:validate": "npm run db:sanity && npm run db:hygiene",
    "lint": "npm --prefix hillside-next run lint && node scripts/run-api-python.mjs -m ruff check hillside-api/app hillside-api/tests",
    "typecheck": "npm --workspace hillside-next run typecheck && npm --workspace @hillside/shared run typecheck",
    "test:api": "node scripts/run-api-python.mjs -m pytest hillside-api/tests -q",
    "test:contracts": "npm --prefix hillside-contracts run test",
    "test": "npm run test:api && npm run test:contracts",
    "quality:gate": "npm run lint && npm run typecheck && npm run test:api && npm run db:validate"
  },
  "devDependencies": {
    "supabase": "^2.78.1"
  }
}
