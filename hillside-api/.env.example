CHAIN_ID_SEPOLIA=11155111
CHAIN_ID_AMOY=80002
CHAIN_ID=80002

ESCROW_CONTRACT_ADDRESS_SEPOLIA=0x0000000000000000000000000000000000000000
ESCROW_CONTRACT_ADDRESS_AMOY=0x0000000000000000000000000000000000000000
GUEST_PASS_CONTRACT_ADDRESS_SEPOLIA=0x0000000000000000000000000000000000000000
GUEST_PASS_CONTRACT_ADDRESS_AMOY=0x0000000000000000000000000000000000000000
