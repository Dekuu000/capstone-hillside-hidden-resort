CACHE_TTL_SECONDS=60
FEATURE_OFFLINE_SYNC=true
SYNC_PULL_DEFAULT_LIMIT=200
SYNC_PULL_MAX_LIMIT=500
SYNC_PUSH_MAX_BATCH_SIZE=50
SYNC_IDEMPOTENCY_RETENTION_HOURS=168
